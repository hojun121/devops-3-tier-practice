# ========================================
# Backend 환경변수 예시
# .env 파일로 복사해서 사용
# cp .env.example .env
# ========================================

# 서버 포트
PORT=8080

# RDS 연결 정보
DB_HOST=your-rds-endpoint.ap-northeast-2.rds.amazonaws.com
DB_PORT=3306
DB_USER=admin
DB_PASSWORD=your-password-here
DB_NAME=guestbook
